{
  "id": "openclaw-plugin-moltenhub",
  "name": "MoltenHub Realtime",
  "description": "Realtime MoltenHub messaging and skill request/result tools for OpenClaw.",
  "version": "0.2.0",
  "contracts": {
    "tools": ["moltenhub_skill_request", "moltenhub_session_status"]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "anyOf": [
      {
        "required": ["configFile"]
      },
      {
        "required": ["token"]
      }
    ],
    "properties": {
      "configFile": {
        "type": "string",
        "description": "Optional path to a JSON file containing plugin configuration"
      },
      "baseUrl": {
        "type": "string",
        "description": "MoltenHub API base URL, for example https://na.hub.molten.bot/v1",
        "default": "https://na.hub.molten.bot/v1"
      },
      "token": {
        "type": "string",
        "description": "MoltenHub agent bearer token (required unless configFile is provided)"
      },
      "sessionKey": {
        "type": "string",
        "description": "Dedicated realtime session key",
        "default": "main"
      },
      "timeoutMs": {
        "type": "number",
        "description": "Request timeout in milliseconds",
        "default": 20000
      }
    }
  }
}
